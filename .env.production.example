APP_NAME="Paz y Salvo AAUD"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://DOMINIO_PRIVADO_AIG
APP_ALLOWED_HOSTS=DOMINIO_PRIVADO_AIG

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_PA

BCRYPT_ROUNDS=12
USER_TEMPORARY_PASSWORD=

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=5432
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_IDLE_TIMEOUT_MINUTES=15
SESSION_REGENERATE_INTERVAL_MINUTES=15
SESSION_ABSOLUTE_TIMEOUT_MINUTES=480
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_DOMAIN=

INTERNAL_NETWORK_ENABLED=true
INTERNAL_ALLOWED_CIDRS=
TRUSTED_PROXIES=

CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local

MAIL_MAILER=log
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

WIDERGY_COMPLETE_DEBTS_URL=https://utilitygo.widergy.com/api/v1/accounts/complete_debts
WIDERGY_JOB_BASE_URL=https://utilitygo-api-4.widergy.com/async_request/jobs
WIDERGY_UTILITY_ID=18
WIDERGY_CHANNEL=web
WIDERGY_CONNECT_TIMEOUT=5
WIDERGY_REQUEST_TIMEOUT=15
WIDERGY_POLL_INTERVAL_MS=1000
WIDERGY_POLL_ATTEMPTS=20

# Debe terminar en /verificar y no incluir el token.
PUBLIC_VERIFICATION_BASE_URL=https://DOMINIO_PUBLICO_AIG/verificar

PAZ_SALVO_DISK=local
PAZ_SALVO_CLIENTS_EXCEL=templates/clientes.xlsx
PAZ_SALVO_TEMPLATE_EXCEL=templates/plantilla_paz_y_salvo.xlsx
PAZ_SALVO_OUTPUT_DIR=generated/paz-salvos
PAZ_SALVO_IDEMPOTENCY_TTL_MINUTES=30
LIBREOFFICE_BINARY=/usr/bin/libreoffice
LIBREOFFICE_TIMEOUT=60
