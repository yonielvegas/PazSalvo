APP_NAME="Paz y Salvo AAUD"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost
APP_ALLOWED_HOSTS=

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_PA

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12
USER_TEMPORARY_PASSWORD=aaud.123

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=paz_salvo_aaud
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_IDLE_TIMEOUT_MINUTES=15
SESSION_REGENERATE_INTERVAL_MINUTES=15
SESSION_ABSOLUTE_TIMEOUT_MINUTES=480
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

INTERNAL_NETWORK_ENABLED=true
INTERNAL_ALLOWED_CIDRS=
TRUSTED_PROXIES=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

WIDERGY_COMPLETE_DEBTS_URL=https://utilitygo.widergy.com/api/v1/accounts/complete_debts
WIDERGY_JOB_BASE_URL=https://utilitygo-api-4.widergy.com/async_request/jobs
WIDERGY_UTILITY_ID=18
WIDERGY_CHANNEL=web
WIDERGY_CONNECT_TIMEOUT=5
WIDERGY_REQUEST_TIMEOUT=15
WIDERGY_POLL_INTERVAL_MS=1000
WIDERGY_POLL_ATTEMPTS=20

# URL base del monolito público de validación. Debe terminar en /verificar y no incluir el token.
PUBLIC_VERIFICATION_BASE_URL=

PAZ_SALVO_DISK=local
PAZ_SALVO_CLIENTS_EXCEL=templates/clientes.xlsx
PAZ_SALVO_TEMPLATE_EXCEL=templates/plantilla_paz_y_salvo.xlsx
PAZ_SALVO_OUTPUT_DIR=generated/paz-salvos
PAZ_SALVO_IDEMPOTENCY_TTL_MINUTES=30
LIBREOFFICE_BINARY=libreoffice
LIBREOFFICE_TIMEOUT=60
