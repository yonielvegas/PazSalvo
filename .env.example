AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

WIDERGY_COMPLETE_DEBTS_URL=https://utilitygo.widergy.com/api/v1/accounts/complete_debts
